{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-carrier-data.github.io/schemas/android-carrier-artifact-registry.schema.json",
  "title": "Open Carrier Data Android source artifact registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "description",
    "sources",
    "scope_coverage",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "registry_id": { "const": "android_carrier_source_artifacts" },
    "description": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "url", "revision", "revision_date", "checked_at"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,63}$" },
          "url": { "type": "string", "format": "uri", "pattern": "^https://" },
          "revision": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "revision_date": { "type": "string", "format": "date" },
          "checked_at": { "type": "string", "format": "date" }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "source",
          "device_scopes",
          "device_ids",
          "regions",
          "build_versions",
          "verification",
          "checked_at"
        ],
        "properties": {
          "artifact_id": { "type": "string", "pattern": "^android:[0-9a-f]{24}$" },
          "source": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,63}$" },
          "device_scopes": { "$ref": "#/$defs/strings" },
          "device_ids": { "$ref": "#/$defs/device_ids" },
          "regions": { "$ref": "#/$defs/strings" },
          "build_versions": { "$ref": "#/$defs/strings" },
          "verification": { "enum": ["indexed", "extracted"] },
          "checked_at": { "type": "string", "format": "date" }
        }
      }
    },
    "scope_coverage": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source",
          "device_scope",
          "scope_kind",
          "device_ids",
          "discovery_status",
          "region_seed_count",
          "probed_region_count",
          "available_region_count",
          "extracted_artifact_count"
        ],
        "properties": {
          "source": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,63}$" },
          "device_scope": { "type": "string", "minLength": 1, "maxLength": 500 },
          "scope_kind": { "enum": ["model", "device_id", "source_api_row"] },
          "device_ids": { "$ref": "#/$defs/device_ids" },
          "discovery_status": {
            "enum": [
              "carrier_data_not_applicable",
              "discovery_in_progress",
              "no_artifact_found",
              "no_query_identifier",
              "artifact_indexed",
              "platform_out_of_scope",
              "source_extracted",
              "source_terms_restrict_extraction"
            ]
          },
          "region_seed_count": { "type": "integer", "minimum": 0 },
          "probed_region_count": { "type": "integer", "minimum": 0 },
          "available_region_count": { "type": "integer", "minimum": 0 },
          "extracted_artifact_count": { "type": "integer", "minimum": 0 }
        }
      }
    }
  },
  "$defs": {
    "strings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    },
    "device_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(android|apple):[a-z0-9-]{3,80}$"
      }
    }
  }
}
