{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/open-carrier-data/open-carrier-data/main/schemas/carrier-profile.schema.json",
  "title": "Open carrier profile",
  "type": "object",
  "required": [
    "schema_version",
    "profile_id",
    "display_name",
    "match",
    "capabilities"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "profile_id": {
      "type": "string",
      "pattern": "^open\\.[0-9]{5,6}\\.[0-9a-f]{12}$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "match": {
      "type": "object",
      "required": [
        "mccmnc"
      ],
      "properties": {
        "mccmnc": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9]{5,6}$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "gid1_prefixes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9A-Fa-f]{1,32}$"
          },
          "uniqueItems": true
        },
        "gid2_prefixes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9A-Fa-f]{1,32}$"
          },
          "uniqueItems": true
        },
        "iccid_prefixes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9]{5,13}$"
          },
          "uniqueItems": true
        },
        "imsi_prefix_patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9xX]{5,10}$"
          },
          "uniqueItems": true
        },
        "spn": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "uniqueItems": true
        },
        "android_carrier_ids": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000000
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "volte": {
          "$ref": "#/$defs/capabilityStatus"
        },
        "vowifi": {
          "$ref": "#/$defs/capabilityStatus"
        },
        "vonr": {
          "$ref": "#/$defs/capabilityStatus"
        },
        "video_calling": {
          "$ref": "#/$defs/capabilityStatus"
        },
        "sms_over_ims": {
          "$ref": "#/$defs/capabilityStatus"
        },
        "mms": {
          "$ref": "#/$defs/capabilityStatus"
        },
        "rcs": {
          "$ref": "#/$defs/capabilityStatus"
        },
        "esim": {
          "$ref": "#/$defs/capabilityStatus"
        },
        "ims_conference": {
          "$ref": "#/$defs/capabilityStatus"
        },
        "wifi_calling_roaming": {
          "$ref": "#/$defs/capabilityStatus"
        }
      }
    },
    "android_carrier_config": {
      "description": "Reviewed Android CarrierConfig subset. Key names and Android value types are fixed.",
      "type": "object",
      "propertyNames": {
        "enum": [
          "allow_add_call_during_video_call",
          "allow_adding_apns_bool",
          "allow_emergency_video_calls_bool",
          "allow_hold_call_during_emergency_bool",
          "allow_hold_in_ims_call",
          "allow_hold_video_call_bool",
          "allow_merge_wifi_calls_when_vowifi_off_bool",
          "allow_merging_rtt_calls_bool",
          "allow_non_emergency_calls_in_ecm_bool",
          "always_play_remote_hold_tone_bool",
          "apn_expand_bool",
          "auto_retry_failed_wifi_emergency_call",
          "call_barring_default_service_class_int",
          "call_barring_supports_deactivate_all_bool",
          "call_barring_supports_password_change_bool",
          "call_forwarding_blocks_while_roaming_string_array",
          "call_forwarding_map_non_number_to_voicemail_bool",
          "carrier_allow_transfer_ims_call_bool",
          "carrier_allow_turnoff_ims_bool",
          "carrier_default_wfc_ims_enabled_bool",
          "carrier_default_wfc_ims_mode_int",
          "carrier_default_wfc_ims_roaming_enabled_bool",
          "carrier_default_wfc_ims_roaming_mode_int",
          "carrier_ims_gba_required_bool",
          "carrier_metered_apn_types_strings",
          "carrier_metered_roaming_apn_types_strings",
          "carrier_promote_wfc_on_call_fail_bool",
          "carrier_supports_ss_over_ut_bool",
          "carrier_use_ims_first_for_emergency_bool",
          "carrier_volte_available_bool",
          "carrier_volte_override_wfc_provisioning_bool",
          "carrier_volte_provisioned_bool",
          "carrier_volte_provisioning_required_bool",
          "carrier_volte_tty_supported_bool",
          "carrier_vowifi_tty_supported_bool",
          "carrier_vt_available_bool",
          "carrier_wfc_ims_available_bool",
          "carrier_wfc_supports_wifi_only_bool",
          "cdma_3waycall_flash_delay_int",
          "default_mtu_int",
          "disable_dun_apn_while_roaming_with_preset_apn_bool",
          "drop_video_call_when_answering_audio_call_bool",
          "editable_enhanced_4g_lte_bool",
          "editable_wfc_mode_bool",
          "editable_wfc_roaming_mode_bool",
          "enableGroupMms",
          "enableMMSDeliveryReports",
          "enableMMSReadReports",
          "enableMultipartSMS",
          "enableSMSDeliveryReports",
          "enabledMMS",
          "enabledNotifyWapMMSC",
          "enabledTransID",
          "enhanced_4g_lte_on_by_default_bool",
          "hide_enhanced_4g_lte_bool",
          "hide_ims_apn_bool",
          "httpParams",
          "httpSocketTimeout",
          "ignore_data_enabled_changed_for_video_calls",
          "ims.enable_presence_capability_exchange_bool",
          "ims.enable_presence_publish_bool",
          "ims.rcs_request_forbidden_by_sip_489_bool",
          "ims.sip_over_ipsec_enabled_bool",
          "ims.use_sip_uri_for_presence_subscribe_bool",
          "ims.use_tel_uri_for_pidf_xml",
          "ims_conference_size_limit_int",
          "ims_dtmf_tone_delay_int",
          "ims_reasoninfo_mapping_string_array",
          "imsvoice.conference_factory_uri_string",
          "imsvoice.conference_subscribe_type_int",
          "is_ims_conference_size_enforced_bool",
          "iwlan.epdg_pco_id_ipv4_int",
          "iwlan.epdg_pco_id_ipv6_int",
          "iwlan.epdg_static_address_string",
          "iwlan.handover_to_wifi_release_delay_second_int",
          "maxImageHeight",
          "maxImageWidth",
          "maxMessageSize",
          "maxMessageTextSize",
          "maxSubjectLength",
          "mmsCloseConnection",
          "notify_handover_video_from_lte_to_wifi_bool",
          "notify_handover_video_from_wifi_to_lte_bool",
          "notify_vt_handover_to_wifi_failure_bool",
          "read_only_apn_fields_string_array",
          "read_only_apn_types_string_array",
          "recipientLimit",
          "rtt_supported_bool",
          "rtt_supported_while_roaming_bool",
          "rtt_upgrade_supported_for_downgraded_vt_call",
          "sendMultipartSmsAsSeparateMessages",
          "show_apn_setting_cdma_bool",
          "show_ims_registration_status_bool",
          "show_wifi_calling_icon_in_status_bar_bool",
          "smsToMmsTextLengthThreshold",
          "smsToMmsTextThreshold",
          "sms_requires_destination_number_conversion_bool",
          "supportMmsContentDisposition",
          "support_3gpp_call_forwarding_while_roaming_bool",
          "support_conference_call_bool",
          "support_downgrade_vt_to_audio_bool",
          "support_ims_conference_call_bool",
          "support_ims_conference_event_package_bool",
          "support_pause_ims_video_calls_bool",
          "support_swap_after_merge_bool",
          "support_video_conference_call_bool",
          "support_wps_over_ims_bool",
          "treat_downgraded_video_calls_as_video_calls_bool",
          "video_calls_can_be_hd_audio",
          "volte_5g_limited_alert_dialog_bool",
          "volte_replacement_rat_int",
          "vt_upgrade_supported_for_downgraded_rtt_call",
          "wfc_data_spn_format_idx_int",
          "wfc_operator_error_codes_string_array",
          "wfc_spn_format_idx_int",
          "wifi_calls_can_be_hd_audio"
        ]
      },
      "properties": {
        "allow_add_call_during_video_call": { "type": "boolean" },
        "allow_hold_in_ims_call": { "type": "boolean" },
        "auto_retry_failed_wifi_emergency_call": { "type": "boolean" },
        "enabledMMS": { "type": "boolean" },
        "enabledNotifyWapMMSC": { "type": "boolean" },
        "enabledTransID": { "type": "boolean" },
        "enableGroupMms": { "type": "boolean" },
        "enableMMSDeliveryReports": { "type": "boolean" },
        "enableMMSReadReports": { "type": "boolean" },
        "enableMultipartSMS": { "type": "boolean" },
        "enableSMSDeliveryReports": { "type": "boolean" },
        "ignore_data_enabled_changed_for_video_calls": { "type": "boolean" },
        "ims.use_tel_uri_for_pidf_xml": { "type": "boolean" },
        "mmsCloseConnection": { "type": "boolean" },
        "rtt_upgrade_supported_for_downgraded_vt_call": { "type": "boolean" },
        "sendMultipartSmsAsSeparateMessages": { "type": "boolean" },
        "supportMmsContentDisposition": { "type": "boolean" },
        "video_calls_can_be_hd_audio": { "type": "boolean" },
        "vt_upgrade_supported_for_downgraded_rtt_call": { "type": "boolean" },
        "wifi_calls_can_be_hd_audio": { "type": "boolean" },
        "httpSocketTimeout": { "type": "integer" },
        "maxImageHeight": { "type": "integer" },
        "maxImageWidth": { "type": "integer" },
        "maxMessageSize": { "type": "integer" },
        "maxMessageTextSize": { "type": "integer" },
        "maxSubjectLength": { "type": "integer" },
        "recipientLimit": { "type": "integer" },
        "smsToMmsTextLengthThreshold": { "type": "integer" },
        "smsToMmsTextThreshold": { "type": "integer" },
        "httpParams": { "type": "string" }
      },
      "patternProperties": {
        "_bool$": { "type": "boolean" },
        "_int$": { "type": "integer" },
        "_string_array$": {
          "type": "array",
          "items": { "type": "string" }
        },
        "_strings$": {
          "type": "array",
          "items": { "type": "string" }
        },
        "_string$": { "type": "string" }
      },
      "additionalProperties": false
    },
    "addons": {
      "type": "object",
      "properties": {
        "emergency_calling": {
          "$ref": "#/$defs/addonNamespace"
        },
        "entitlement": {
          "$ref": "#/$defs/addonNamespace"
        },
        "euc": {
          "$ref": "#/$defs/addonNamespace"
        },
        "ims": {
          "$ref": "#/$defs/addonNamespace"
        },
        "messaging": {
          "$ref": "#/$defs/addonNamespace"
        },
        "network_policy": {
          "$ref": "#/$defs/addonNamespace"
        },
        "operator_display": {
          "$ref": "#/$defs/addonNamespace"
        },
        "presence": {
          "$ref": "#/$defs/addonNamespace"
        },
        "provisioning": {
          "$ref": "#/$defs/addonNamespace"
        },
        "rcs": {
          "$ref": "#/$defs/addonNamespace"
        },
        "wifi_calling": {
          "$ref": "#/$defs/addonNamespace"
        }
      },
      "additionalProperties": false
    },
    "android_apns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "apn",
          "types"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "apn": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "types": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "*",
                "default",
                "mms",
                "supl",
                "dun",
                "hipri",
                "fota",
                "ims",
                "cbs",
                "ia",
                "emergency",
                "mcx",
                "xcap",
                "vsim",
                "bip",
                "enterprise",
                "rcs"
              ]
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "mmsc": {
            "type": "string",
            "maxLength": 240
          },
          "mmsproxy": {
            "type": "string",
            "maxLength": 120
          },
          "mmsport": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "proxy": {
            "type": "string",
            "maxLength": 120
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "server": {
            "type": "string",
            "maxLength": 120
          },
          "user": {
            "type": "string",
            "maxLength": 120
          },
          "password": {
            "type": "string",
            "maxLength": 120
          },
          "authtype": {
            "type": "integer",
            "minimum": -1,
            "maximum": 3
          },
          "bearer": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "bearer_bitmask": {
            "type": "string",
            "maxLength": 120
          },
          "network_type_bitmask": {
            "type": "string",
            "maxLength": 120
          },
          "lingering_network_type_bitmask": {
            "type": "string",
            "maxLength": 120
          },
          "infrastructure_bitmask": {
            "type": "string",
            "maxLength": 40
          },
          "mtu": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          },
          "mtu_v4": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          },
          "mtu_v6": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          },
          "carrier_id": {
            "type": "integer",
            "minimum": -1,
            "maximum": 1000000
          },
          "profile_id": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000000
          },
          "apn_set_id": {
            "type": "integer",
            "minimum": -1,
            "maximum": 1000000
          },
          "skip_464xlat": {
            "type": "integer",
            "minimum": -1,
            "maximum": 1
          },
          "max_conns": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000000
          },
          "max_conns_time": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000000
          },
          "wait_time": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000000
          },
          "user_visible": {
            "type": "boolean"
          },
          "user_editable": {
            "type": "boolean"
          },
          "carrier_enabled": {
            "type": "boolean"
          },
          "modem_cognitive": {
            "type": "boolean"
          },
          "always_on": {
            "type": "boolean"
          },
          "esim_bootstrap_provisioning": {
            "type": "boolean"
          },
          "mvno_type": {
            "type": "string",
            "enum": [
              "spn",
              "gid",
              "imsi",
              "iccid"
            ]
          },
          "mvno_match_data": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "protocol": {
            "type": "string",
            "enum": [
              "IP",
              "IPV6",
              "IPV4V6",
              "PPP",
              "NON-IP",
              "UNSTRUCTURED"
            ]
          },
          "roaming_protocol": {
            "type": "string",
            "enum": [
              "IP",
              "IPV6",
              "IPV4V6",
              "PPP",
              "NON-IP",
              "UNSTRUCTURED"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "capabilityStatus": {
      "type": "string",
      "enum": [
        "supported",
        "unsupported",
        "conditional",
        "unknown"
      ]
    },
    "addonNamespace": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]{2,80}$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/addonValue"
      }
    },
    "addonValue": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "integer",
          "minimum": -1000000,
          "maximum": 1000000
        },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        {
          "type": "array",
          "maxItems": 40,
          "items": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "integer",
                "minimum": -1000000,
                "maximum": 1000000
              },
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 160
              }
            ]
          }
        }
      ]
    }
  },
  "additionalProperties": false
}
