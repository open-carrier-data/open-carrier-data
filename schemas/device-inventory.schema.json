{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-carrier-data.github.io/schemas/device-inventory.schema.json",
  "title": "Open Carrier Data device inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "inventory_id",
    "platform",
    "description",
    "sources",
    "devices"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "inventory_id": { "type": "string", "minLength": 1 },
    "platform": { "enum": ["android", "apple"] },
    "description": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/source" }
    },
    "devices": {
      "type": "array",
      "items": { "$ref": "#/$defs/device" }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url", "revision", "revision_date", "checked_at"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,63}$" },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "revision": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "revision_date": { "type": "string", "format": "date" },
        "checked_at": { "type": "string", "format": "date" }
      }
    },
    "strings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    },
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "device_id",
        "platform",
        "identity_basis",
        "brands",
        "device_names",
        "models",
        "marketing_names",
        "inventory_status",
        "inventory_sources"
      ],
      "properties": {
        "device_id": {
          "type": "string",
          "pattern": "^(android|apple):[a-z0-9-]{3,80}$"
        },
        "platform": { "enum": ["android", "apple"] },
        "identity_basis": { "type": "string", "minLength": 1 },
        "brands": { "$ref": "#/$defs/strings" },
        "device_names": { "$ref": "#/$defs/strings" },
        "models": { "$ref": "#/$defs/strings" },
        "marketing_names": { "$ref": "#/$defs/strings" },
        "family": { "type": "string", "minLength": 1 },
        "inventory_status": { "enum": ["present", "historical"] },
        "inventory_sources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source",
              "status",
              "first_seen_revision",
              "last_changed_revision"
            ],
            "properties": {
              "source": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,63}$" },
              "status": { "enum": ["present", "historical"] },
              "first_seen_revision": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "last_changed_revision": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
            }
          }
        },
        "carrier_observations": {
          "type": "object",
          "additionalProperties": false,
          "required": ["matched_identifiers", "profile_count", "sources"],
          "properties": {
            "matched_identifiers": { "$ref": "#/$defs/strings" },
            "profile_count": { "type": "integer", "minimum": 1 },
            "sources": { "$ref": "#/$defs/strings" }
          }
        },
        "carrier_artifact_catalog": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifact_count",
            "match_kind",
            "scopes",
            "source",
            "verified_artifact_count"
          ],
          "properties": {
            "artifact_count": { "type": "integer", "minimum": 1 },
            "match_kind": { "enum": ["exact_product_type", "product_family"] },
            "scopes": { "$ref": "#/$defs/strings" },
            "source": { "const": "apple_carrier_bundles" },
            "verified_artifact_count": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
