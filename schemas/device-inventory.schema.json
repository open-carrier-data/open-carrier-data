{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-carrier-data.github.io/schemas/device-inventory.schema.json",
  "title": "Open Carrier Data device inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "inventory_id",
    "platform",
    "description",
    "sources",
    "devices"
  ],
  "properties": {
    "schema_version": { "type": "integer", "enum": [1, 2] },
    "inventory_id": { "type": "string", "minLength": 1 },
    "platform": { "enum": ["android", "apple"] },
    "description": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/source" }
    },
    "devices": {
      "type": "array",
      "items": { "$ref": "#/$defs/device" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "platform": { "const": "android" } },
        "required": ["platform"]
      },
      "then": {
        "properties": {
          "devices": {
            "items": {
              "properties": {
                "platform": { "const": "android" },
                "device_id": { "pattern": "^android:[a-z0-9-]{3,80}$" }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "platform": { "const": "apple" } },
        "required": ["platform"]
      },
      "then": {
        "properties": {
          "devices": {
            "items": {
              "properties": {
                "platform": { "const": "apple" },
                "device_id": { "pattern": "^apple:[a-z0-9-]{3,80}$" }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "schema_version": { "const": 1 } },
        "required": ["schema_version"]
      },
      "then": {
        "properties": {
          "devices": {
            "items": { "not": { "required": ["carrier_relevance"] } }
          }
        }
      },
      "else": {
        "properties": {
          "devices": {
            "items": { "required": ["carrier_relevance"] }
          }
        }
      }
    }
  ],
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url", "revision", "revision_date", "checked_at"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,63}$" },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "revision": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "revision_date": { "type": "string", "format": "date" },
        "checked_at": { "type": "string", "format": "date" }
      }
    },
    "strings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    },
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "device_id",
        "platform",
        "identity_basis",
        "brands",
        "device_names",
        "models",
        "marketing_names",
        "inventory_status",
        "inventory_sources",
        "carrier_data_coverage"
      ],
      "properties": {
        "device_id": {
          "type": "string",
          "pattern": "^(android|apple):[a-z0-9-]{3,80}$"
        },
        "platform": { "enum": ["android", "apple"] },
        "identity_basis": { "type": "string", "minLength": 1 },
        "brands": { "$ref": "#/$defs/strings" },
        "device_names": { "$ref": "#/$defs/strings" },
        "models": { "$ref": "#/$defs/strings" },
        "marketing_names": { "$ref": "#/$defs/strings" },
        "family": { "type": "string", "minLength": 1 },
        "inventory_status": { "enum": ["present", "historical"] },
        "inventory_sources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source",
              "status",
              "first_seen_revision",
              "last_changed_revision"
            ],
            "properties": {
              "source": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,63}$" },
              "status": { "enum": ["present", "historical"] },
              "first_seen_revision": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "last_changed_revision": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
            }
          }
        },
        "carrier_observations": {
          "type": "object",
          "additionalProperties": false,
          "required": ["matched_identifiers", "profile_count", "sources"],
          "properties": {
            "matched_identifiers": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true,
              "description": "The stable device_id uniquely bound to this observation.",
              "items": {
                "type": "string",
                "pattern": "^(android|apple):[a-z0-9-]{3,80}$"
              }
            },
            "profile_count": { "type": "integer", "minimum": 1 },
            "sources": { "$ref": "#/$defs/strings" }
          }
        },
        "carrier_artifact_catalog": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifact_count",
            "match_kind",
            "scopes",
            "source",
            "verified_artifact_count"
          ],
          "properties": {
            "artifact_count": { "type": "integer", "minimum": 1 },
            "match_kind": { "enum": ["exact_product_type", "product_family"] },
            "scopes": { "$ref": "#/$defs/strings" },
            "source": { "const": "apple_carrier_bundles" },
            "verified_artifact_count": { "type": "integer", "minimum": 0 }
          }
        },
        "carrier_source_catalogs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source",
              "match_kind",
              "matched_identifiers",
              "artifact_count",
              "indexed_artifact_count",
              "extracted_artifact_count"
            ],
            "properties": {
              "source": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,63}$" },
              "match_kind": { "enum": ["exact_device_id", "exact_model"] },
              "matched_identifiers": { "$ref": "#/$defs/strings" },
              "artifact_count": { "type": "integer", "minimum": 1 },
              "indexed_artifact_count": { "type": "integer", "minimum": 0 },
              "extracted_artifact_count": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "carrier_source_discovery": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "matched_identifiers", "scope_count", "status_counts"],
            "properties": {
              "source": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,63}$" },
              "matched_identifiers": {
                "type": "array",
                "minItems": 1,
                "maxItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "pattern": "^(android|apple):[a-z0-9-]{3,80}$"
                }
              },
              "scope_count": { "type": "integer", "minimum": 1 },
              "status_counts": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "discovery_in_progress": { "type": "integer", "minimum": 1 },
                  "no_artifact_found": { "type": "integer", "minimum": 1 },
                  "no_query_identifier": { "type": "integer", "minimum": 1 },
                  "artifact_indexed": { "type": "integer", "minimum": 1 },
                  "carrier_data_not_applicable": { "type": "integer", "minimum": 1 },
                  "platform_out_of_scope": { "type": "integer", "minimum": 1 },
                  "source_extracted": { "type": "integer", "minimum": 1 },
                  "source_authentication_required": { "type": "integer", "minimum": 1 },
                  "source_transport_untrusted": { "type": "integer", "minimum": 1 },
                  "source_terms_restrict_extraction": { "type": "integer", "minimum": 1 }
                },
                "minProperties": 1
              }
            }
          }
        },
        "carrier_data_coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "sources"],
          "properties": {
            "status": {
              "enum": [
                "carrier_data_not_applicable",
                "exact_carrier_data_observed",
                "exact_source_extracted",
                "exact_source_verified",
                "exact_source_indexed",
                "family_source_verified",
                "family_source_indexed",
                "source_discovery_in_progress",
                "source_checked_no_artifact",
                "source_not_queryable",
                "platform_out_of_scope",
                "source_authentication_required",
                "source_transport_untrusted",
                "source_terms_restrict_extraction",
                "inventory_only"
              ]
            },
            "sources": { "$ref": "#/$defs/strings" }
          }
        },
        "carrier_relevance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "evidence"],
          "properties": {
            "status": {
              "enum": [
                "evidence_confirmed_cellular",
                "evidence_confirmed_non_cellular",
                "not_established"
              ]
            },
            "evidence": {
              "type": "array",
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/carrier_relevance_evidence" }
            }
          },
          "allOf": [
            {
              "if": {
                "properties": { "status": { "const": "not_established" } },
                "required": ["status"]
              },
              "then": {
                "properties": { "evidence": { "maxItems": 0 } }
              },
              "else": {
                "properties": { "evidence": { "minItems": 1 } }
              }
            },
            {
              "if": {
                "properties": {
                  "status": { "const": "evidence_confirmed_non_cellular" }
                },
                "required": ["status"]
              },
              "then": {
                "properties": {
                  "evidence": {
                    "items": {
                      "properties": {
                        "kind": {
                          "enum": [
                            "official_connectivity_specification",
                            "official_connectivity_variant"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "platform": { "const": "android" } },
            "required": ["platform"]
          },
          "then": {
            "properties": {
              "device_id": { "pattern": "^android:[a-z0-9-]{3,80}$" },
              "carrier_relevance": {
                "properties": {
                  "evidence": {
                    "items": {
                      "properties": {
                        "kind": {
                          "enum": [
                            "exact_carrier_observation",
                            "extracted_carrier_configuration",
                            "official_connectivity_specification",
                            "official_connectivity_variant"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "platform": { "const": "apple" } },
            "required": ["platform"]
          },
          "then": {
            "properties": {
              "device_id": { "pattern": "^apple:[a-z0-9-]{3,80}$" },
              "carrier_relevance": {
                "properties": {
                  "evidence": {
                    "items": {
                      "properties": {
                        "kind": {
                          "enum": [
                            "exact_product_type_carrier_bundle",
                            "official_connectivity_specification",
                            "official_connectivity_variant"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "carrier_relevance": {
                "properties": {
                  "evidence": {
                    "contains": {
                      "properties": {
                        "kind": { "const": "exact_carrier_observation" }
                      },
                      "required": ["kind"]
                    }
                  }
                },
                "required": ["evidence"]
              }
            },
            "required": ["carrier_relevance"]
          },
          "then": {
            "properties": {
              "platform": { "const": "android" },
              "carrier_observations": {
                "properties": {
                  "matched_identifiers": {
                    "minItems": 1,
                    "maxItems": 1,
                    "items": {
                      "type": "string",
                      "pattern": "^android:[a-z0-9-]{3,80}$"
                    }
                  }
                }
              }
            },
            "required": ["carrier_observations"]
          }
        },
        {
          "if": {
            "properties": {
              "carrier_relevance": {
                "properties": {
                  "evidence": {
                    "contains": {
                      "properties": {
                        "kind": { "const": "extracted_carrier_configuration" }
                      },
                      "required": ["kind"]
                    }
                  }
                },
                "required": ["evidence"]
              }
            },
            "required": ["carrier_relevance"]
          },
          "then": {
            "properties": {
              "platform": { "const": "android" },
              "carrier_source_catalogs": {
                "minItems": 1,
                "items": {
                  "properties": {
                    "match_kind": { "const": "exact_device_id" },
                    "matched_identifiers": {
                      "minItems": 1,
                      "maxItems": 1,
                      "items": {
                        "type": "string",
                        "pattern": "^android:[a-z0-9-]{3,80}$"
                      }
                    }
                  }
                }
              }
            },
            "required": ["carrier_source_catalogs"]
          }
        },
        {
          "if": {
            "properties": {
              "carrier_relevance": {
                "properties": {
                  "evidence": {
                    "contains": {
                      "properties": {
                        "kind": { "const": "exact_product_type_carrier_bundle" }
                      },
                      "required": ["kind"]
                    }
                  }
                },
                "required": ["evidence"]
              }
            },
            "required": ["carrier_relevance"]
          },
          "then": {
            "properties": {
              "platform": { "const": "apple" },
              "carrier_artifact_catalog": {
                "properties": {
                  "match_kind": { "const": "exact_product_type" }
                },
                "required": ["match_kind"]
              }
            },
            "required": ["carrier_artifact_catalog"]
          }
        },
        {
          "if": {
            "properties": {
              "carrier_data_coverage": {
                "properties": {
                  "status": { "const": "source_transport_untrusted" }
                },
                "required": ["status"]
              }
            },
            "required": ["carrier_data_coverage"]
          },
          "then": {
            "properties": {
              "platform": { "const": "android" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "carrier_source_discovery": {
                "contains": {
                  "type": "object",
                  "properties": {
                    "status_counts": {
                      "type": "object",
                      "required": ["source_authentication_required"]
                    }
                  },
                  "required": ["status_counts"]
                }
              }
            },
            "required": ["carrier_source_discovery"]
          },
          "then": {
            "properties": {
              "platform": { "const": "android" },
              "carrier_data_coverage": {
                "properties": {
                  "status": { "const": "source_authentication_required" }
                },
                "required": ["status"]
              }
            },
            "required": ["carrier_data_coverage"]
          }
        },
        {
          "if": {
            "properties": {
              "carrier_data_coverage": {
                "properties": {
                  "status": { "const": "source_authentication_required" }
                },
                "required": ["status"]
              }
            },
            "required": ["carrier_data_coverage"]
          },
          "then": {
            "properties": {
              "platform": { "const": "android" },
              "carrier_source_discovery": {
                "contains": {
                  "type": "object",
                  "properties": {
                    "status_counts": {
                      "type": "object",
                      "required": ["source_authentication_required"]
                    }
                  },
                  "required": ["status_counts"]
                }
              }
            },
            "required": ["carrier_source_discovery"],
            "not": {
              "anyOf": [
                { "required": ["carrier_observations"] },
                { "required": ["carrier_artifact_catalog"] },
                { "required": ["carrier_source_catalogs"] }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "carrier_relevance": {
                "properties": {
                  "status": { "const": "evidence_confirmed_non_cellular" }
                },
                "required": ["status"]
              }
            },
            "required": ["carrier_relevance"]
          },
          "then": {
            "properties": {
              "carrier_data_coverage": {
                "properties": {
                  "status": { "const": "carrier_data_not_applicable" }
                },
                "required": ["status"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "carrier_data_coverage": {
                "properties": {
                  "status": { "const": "carrier_data_not_applicable" }
                },
                "required": ["status"]
              }
            },
            "required": ["carrier_data_coverage", "carrier_relevance"]
          },
          "then": {
            "properties": {
              "carrier_relevance": {
                "properties": {
                  "status": { "const": "evidence_confirmed_non_cellular" }
                },
                "required": ["status"]
              }
            }
          }
        }
      ]
    },
    "carrier_relevance_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "source"],
      "properties": {
        "kind": {
          "enum": [
            "exact_carrier_observation",
            "extracted_carrier_configuration",
            "exact_product_type_carrier_bundle",
            "official_connectivity_specification",
            "official_connectivity_variant"
          ]
        },
        "source": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_]{1,63}$"
        }
      }
    }
  }
}
